// ============================================================
async function mostrarResultado(premio) {
  // Registra no Sheets
  const codigo = gerarCodigo();
  const agora = new Date();
  const dataStr = agora.toLocaleDateString('pt-BR') + ' ' + agora.toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'});

  try {
    await fetch(`${APPS_SCRIPT_URL}?acao=registrar&senha=${encodeURIComponent(senhaAtual)}&nome=${encodeURIComponent(nomeAtual)}&premio=${encodeURIComponent(premio.nome)}&codigo=${encodeURIComponent(codigo)}`);
  } catch(e) { /* registra mesmo sem confirmação */ }

  resultadoAtual = { premio, codigo, data: dataStr, nome: nomeAtual };

  document.getElementById('res-emoji').textContent = premio.emoji || '🎉';
  document.getElementById('res-premio').textContent = premio.nome;
  document.getElementById('res-vendedor').textContent = nomeAtual;
  document.getElementById('res-data').textContent = dataStr;
  document.getElementById('res-codigo').textContent = codigo;

  document.getElementById('screen-roleta').style.display = 'none';
  document.getElementById('screen-resultado').style.display = 'block';

  lancarConfetti();
}

function gerarCodigo() {
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let cod = 'KB-';
  for (let i = 0; i < 6; i++) cod += chars[Math.floor(Math.random() * chars.length)];
  return cod;
}

function lancarConfetti() {
  const cores = ['#F4721B','#FFD700','#FF6B9D','#4CAF50','#9C27B0','#2196F3'];
  for (let i = 0; i < 60; i++) {
    setTimeout(() => {
      const el = document.createElement('div');
      el.className = 'confetti-piece';
      el.style.left = Math.random() * 100 + 'vw';
      el.style.backgroundColor = cores[Math.floor(Math.random() * cores.length)];
      el.style.width = (8 + Math.random() * 8) + 'px';
      el.style.height = (8 + Math.random() * 8) + 'px';
      el.style.animationDuration = (1.5 + Math.random() * 2) + 's';
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 4000);
    }, i * 40);
  }
}

// ============================================================
// GERAR CUPOM (IMAGEM)
// ============================================================
async function gerarCupom() {
  const btn = document.getElementById('btn-gerar-cupom');
  btn.innerHTML = '<span class="loading"></span>Gerando...';
  btn.disabled = true;

  const canvas = document.getElementById('cupom-canvas');
  canvas.style.display = 'block';
  const ctx = canvas.getContext('2d');
  const W = 800, H = 1000;

  // Fundo gradiente laranja
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, '#F4721B');
  grad.addColorStop(0.5, '#C45A0E');
  grad.addColorStop(1, '#6B3A1F');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, W, H);

  // Padrão de bolinhas sutis
  ctx.fillStyle = 'rgba(255,255,255,0.05)';
  for (let x = 0; x < W; x += 40) {
    for (let y = 0; y < H; y += 40) {
      ctx.beginPath();
      ctx.arc(x, y, 15, 0, 2*Math.PI);
      ctx.fill();
    }
  }

  // Card branco central
  const cardX = 40, cardY = 200, cardW = W-80, cardH = 600;
  ctx.fillStyle = 'white';
  roundRect(ctx, cardX, cardY, cardW, cardH, 32);
  ctx.fill();

  // GRUPO KUHN topo
  ctx.fillStyle = 'white';
  ctx.font = 'bold 24px Nunito, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('GRUPO KUHN', W/2, 80);
  ctx.font = 'bold 48px Fredoka One, cursive';
  ctx.fillText('Roleta da Páscoa 🐣', W/2, 140);
  ctx.font = '22px Nunito, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.8)';
  ctx.fillText('Chilli Beans', W/2, 175);

  // Emoji grande
  ctx.font = '80px serif';
  ctx.textAlign = 'center';
  ctx.fillText(resultadoAtual.premio.emoji || '🎉', W/2, cardY + 110);

  // "Você ganhou"
  ctx.fillStyle = '#8B6347';
  ctx.font = 'bold 26px Nunito, sans-serif';
  ctx.fillText('🎊 PARABÉNS, VOCÊ GANHOU:', W/2, cardY + 165);

  // Nome do prêmio
  ctx.fillStyle = '#F4721B';
  ctx.font = 'bold 52px Fredoka One, cursive';
  wrapText(ctx, resultadoAtual.premio.nome, W/2, cardY + 230, cardW - 60, 58);

  // Linha divisória pontilhada
  ctx.strokeStyle = '#F0E0D0';
  ctx.setLineDash([8, 6]);
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(cardX + 40, cardY + 330);
  ctx.lineTo(cardX + cardW - 40, cardY + 330);
  ctx.stroke();
  ctx.setLineDash([]);

  // Infos
  ctx.textAlign = 'left';
  const col1 = cardX + 50, col2 = cardX + cardW/2;
  const rowY = cardY + 385;

  ctx.fillStyle = '#BBB';
  ctx.font = 'bold 16px Nunito, sans-serif';
  ctx.fillText('VENDEDOR', col1, rowY - 20);
  ctx.fillText('DATA', col2, rowY - 20);

  ctx.fillStyle = '#3A2010';
  ctx.font = 'bold 22px Nunito, sans-serif';
  ctx.fillText(resultadoAtual.nome, col1, rowY + 8);
  ctx.fillText(resultadoAtual.data, col2, rowY + 8);

  // Código cupom
  ctx.fillStyle = '#FFF8EE';
  roundRect(ctx, cardX + 40, cardY + 430, cardW - 80, 100, 16);
  ctx.fill();

  ctx.strokeStyle = '#F4721B';
  ctx.setLineDash([8, 6]);
  ctx.lineWidth = 3;
  roundRect(ctx, cardX + 40, cardY + 430, cardW - 80, 100, 16);
  ctx.stroke();
  ctx.setLineDash([]);

  ctx.textAlign = 'center';
  ctx.fillStyle = '#AAA';
  ctx.font = 'bold 16px Nunito, sans-serif';
  ctx.fillText('CÓDIGO DO CUPOM', W/2, cardY + 468);

  ctx.fillStyle = '#F4721B';
  ctx.font = 'bold 44px Fredoka One, cursive';
  ctx.letterSpacing = '6px';
  ctx.fillText(resultadoAtual.codigo, W/2, cardY + 518);

  // Validade
  ctx.fillStyle = '#CCC';
  ctx.font = '18px Nunito, sans-serif';
  ctx.fillText('Válido para resgate nesta data • Apresente ao gerente', W/2, cardY + 570);

  // Rodapé
  ctx.fillStyle = 'rgba(255,255,255,0.6)';
  ctx.font = '20px Nunito, sans-serif';
  ctx.fillText('grupo-kuhn.com.br  •  Páscoa 2025', W/2, H - 30);

  // Baixar / compartilhar
  const dataURL = canvas.toDataURL('image/png');
  canvas.style.display = 'none';

  // Tenta Web Share API (mobile)
  if (navigator.share && navigator.canShare) {
    try {
      const blob = await (await fetch(dataURL)).blob();
      const file = new File([blob], 'cupom-pascoa-kuhn.png', { type: 'image/png' });
      if (navigator.canShare({ files: [file] })) {
        await navigator.share({ files: [file], title: 'Meu prêmio da Páscoa - Grupo Kuhn' });
        btn.innerHTML = '✅ Compartilhado!';
        btn.disabled = false;
        return;
      }
    } catch(e) {}
  }

  // Fallback: download
  const a = document.createElement('a');
  a.href = dataURL;
  a.download = 'cupom-pascoa-kuhn.png';
  a.click();

  btn.innerHTML = '✅ Imagem baixada!';
  btn.disabled = false;
}

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

function wrapText(ctx, text, x, y, maxW, lineH) {
  const words = text.split(' ');
  let line = '';
  let lines = [];
  for (const word of words) {
    const test = line + word + ' ';
    if (ctx.measureText(test).width > maxW && line) {
      lines.push(line.trim());
      line = word + ' ';
    } else { line = test; }
  }
  lines.push(line.trim());
  const startY = y - ((lines.length - 1) * lineH) / 2;
  lines.forEach((l, i) => ctx.fillText(l, x, startY + i * lineH));
}
